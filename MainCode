@Composable
fun CustomerHomeScreen(
    studentName: String, cartCount: Int, globalOrders: MutableList<Order>,
    onNavigateToCart: () -> Unit, onAddToCart: (MenuItem) -> Unit, onLogout: () -> Unit
) {
    val haptic = LocalHapticFeedback.current
    val menuItems = listOf(
        MenuItem("1", "Cheese Burger", "🍔", 120.0, "Juicy patty with double cheese", "Ingredients: Beef, Cheese, Tomato, Onion, Gluten Bun"),
        MenuItem("2", "Cold Frappe", "☕", 95.0, "Refreshing iced coffee with cream", "Ingredients: Arabica Coffee, Milk, Sugar, Cream, Chocolate Syrup"),
        MenuItem("3", "Spicy Pizza", "🍕", 250.0, "Wood-fired pizza with jalapenos", "Ingredients: Flour dough, Tomato sauce, Mozzarella, Jalapenos, Oregano"),
        MenuItem("4", "Loaded Fries", "🍟", 80.0, "Crispy fries topped with cheese sauce", "Ingredients: Potato, Cheese Sauce, Paprika, Salt, Soybean Oil")
    )
    
    val readyOrders = globalOrders.filter { it.studentName == studentName && it.status == "Ready" }
    val hasNotification = readyOrders.isNotEmpty()
    
    // Cinmestic Frosted Glass Blur when notification hits
    val blurRadius by animateDpAsState(if (hasNotification) 16.dp else 0.dp, label = "BlurState")

    Box(modifier = Modifier.fillMaxSize().background(DarkBackground)) {
        
        // BACKGROUND LAYER (Automatically blurs out strongly if Notification appears!)
        Column(modifier = Modifier.fillMaxSize().blur(blurRadius)) {
            Row(modifier = Modifier.fillMaxWidth().padding(24.dp), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                Column {
                    Text("Morning, $studentName 👋", fontSize = 16.sp, color = TextGray)
                    Text("Hungry today?", fontSize = 28.sp, fontWeight = FontWeight.Bold)
                }
                Box(modifier = Modifier.size(50.dp).clip(CircleShape).background(CardBackground).bounceClick(onNavigateToCart), contentAlignment = Alignment.Center) {
                    Icon(Icons.Default.ShoppingCart, contentDescription = "Cart", tint = PrimaryColor)
                    if (cartCount > 0) {
                        Box(modifier = Modifier.align(Alignment.TopEnd).offset((-4).dp, 4.dp).size(20.dp).clip(CircleShape).background(Color.Red), contentAlignment = Alignment.Center) {
                            Text(cartCount.toString(), color = Color.White, fontSize = 10.sp, fontWeight = FontWeight.Bold)
                        }
                    }
                }
            }

            // AUTO-SCROLLING PROMO HERO CAROUSEL
            val promoState = rememberLazyListState()
            val promos = listOf(Triple("50% OFF TODAY", "Try the Spicy Pizza!", Color(0xFFEF4444)), Triple("NEW ARRIVAL", "Refresh with a Frappe", Color(0xFF3B82F6)), Triple("COMBO DEAL", "Burger + Fries", Color(0xFF10B981)))
            
            LaunchedEffect(Unit) {
                while(true) {
                    delay(4000)
                    if(!hasNotification) { // Only scroll if they aren't looking at a notification
                        val next = (promoState.firstVisibleItemIndex + 1) % promos.size
                        promoState.animateScrollToItem(next)
                    }
                }
            }
            LazyRow(state = promoState, modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp), contentPadding = PaddingValues(horizontal = 24.dp)) {
                items(promos) { promo ->
                    Box(modifier = Modifier.width(300.dp).height(120.dp).padding(end = 16.dp).clip(RoundedCornerShape(20.dp)).background(promo.third).padding(20.dp), contentAlignment = Alignment.CenterStart) {
                        Column {
                            Text(promo.first, color = Color.White, fontWeight = FontWeight.ExtraBold, fontSize = 22.sp)
                            Text(promo.second, color = Color.White, fontSize = 16.sp)
                        }
                    }
                }
            }

            Text("Popular Menu", modifier = Modifier.padding(horizontal = 24.dp), fontSize = 22.sp, fontWeight = FontWeight.Bold)
            Text("Tap any card to spin and reveal ingredients!", modifier = Modifier.padding(horizontal = 24.dp), fontSize = 12.sp, color = TextGray)
            Spacer(modifier = Modifier.height(16.dp))

            LazyColumn(contentPadding = PaddingValues(horizontal = 24.dp, vertical = 8.dp)) {
                items(menuItems) { item ->
                    var flipped by remember { mutableStateOf(false) }
                    val rotation by animateFloatAsState(targetValue = if (flipped) 180f else 0f, animationSpec = tween(durationMillis = 600, easing = FastOutSlowInEasing), label = "3DFlip")

                    Box(
                        modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp).graphicsLayer { rotationY = rotation; cameraDistance = 16f * density }
                            .clickable {
                                flipped = !flipped
                                haptic.performHapticFeedback(HapticFeedbackType.TextHandleMove) // tiny buzz on flip!
                            } 
                    ) {
                        if (rotation <= 90f) {
                            Card(shape = RoundedCornerShape(20.dp), colors = CardDefaults.cardColors(containerColor = CardBackground)) {
                                Row(modifier = Modifier.padding(16.dp).fillMaxWidth(), verticalAlignment = Alignment.CenterVertically) {
                                    Box(modifier = Modifier.size(60.dp).clip(RoundedCornerShape(16.dp)).background(Color(0xFF334155)), contentAlignment = Alignment.Center) { Text(item.emoji, fontSize = 32.sp) }
                                    Spacer(modifier = Modifier.width(16.dp))
                                    Column(modifier = Modifier.weight(1f)) {
                                        Text(item.name, fontSize = 18.sp, fontWeight = FontWeight.Bold)
                                        Text("₹${item.price}", fontSize = 16.sp, fontWeight = FontWeight.ExtraBold, color = PrimaryColor)
                                    }
                                    Box(modifier = Modifier.size(40.dp).clip(CircleShape).background(PrimaryColor).bounceClick { onAddToCart(item) }, contentAlignment = Alignment.Center) { Icon(Icons.Default.Add, contentDescription = "Add", tint = Color.White) }
                                }
                            }
                        } else {
                            Card(shape = RoundedCornerShape(20.dp), colors = CardDefaults.cardColors(containerColor = CardBackground), modifier = Modifier.graphicsLayer { rotationY = 180f }) {
                                Column(modifier = Modifier.fillMaxWidth().height(92.dp).padding(16.dp), verticalArrangement = Arrangement.Center) {
                                    Text("Dietary Info:", fontWeight = FontWeight.Bold, color = PrimaryColor, fontSize = 14.sp)
                                    Text(item.ingredients, color = Color.White, fontSize = 13.sp)
                                }
                            }
                        }
                    }
                }
                item {
                    Spacer(modifier = Modifier.height(30.dp))
                    TextButton(onClick = onLogout, modifier = Modifier.fillMaxWidth()) { Text("Logout", color = Color.Red) }
                }
            }
        }
        
        // FOREGROUND OVERLAY: THE CINEMATIC NOTIFICATION 
        if (hasNotification) {
            Box(modifier = Modifier.fillMaxSize().background(Color(0x88000000)), contentAlignment = Alignment.Center) {
                Card(
                    modifier = Modifier.fillMaxWidth().padding(32.dp),
                    shape = RoundedCornerShape(24.dp), colors = CardDefaults.cardColors(containerColor = Color(0xFF10B981))
                ) {
                    Column(modifier = Modifier.padding(32.dp), horizontalAlignment = Alignment.CenterHorizontally) {
                        Text("🔔", fontSize = 60.sp)
                        Spacer(modifier = Modifier.height(16.dp))
                        Text("ORDER READY!", fontWeight = FontWeight.ExtraBold, color = Color.White, fontSize = 28.sp)
                        Spacer(modifier = Modifier.height(8.dp))
                        readyOrders.forEach { order ->
                            Text("Show Token ${order.token} to the cashier right now to collect your food.", color = Color.White, textAlign = TextAlign.Center)
                        }
                        Spacer(modifier = Modifier.height(24.dp))
                        Box(modifier = Modifier.fillMaxWidth().height(50.dp).bounceClick { 
                            haptic.performHapticFeedback(HapticFeedbackType.LongPress)
                            globalOrders.removeAll(readyOrders)
                        }.background(Color.White, RoundedCornerShape(12.dp)), contentAlignment = Alignment.Center) {
                            Text("I'm on my way!", color = Color(0xFF10B981), fontWeight = FontWeight.Bold)
                        }
                    }
                }
                
                // Triggers massive vibration on notification appearance
                LaunchedEffect(Unit) {
                    haptic.performHapticFeedback(HapticFeedbackType.LongPress)
                    delay(200)
                    haptic.performHapticFeedback(HapticFeedbackType.LongPress)
                }
            }
        }
    }
}

