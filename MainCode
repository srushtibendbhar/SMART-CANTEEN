@Composable
fun CanteenApp() {
    var currentScreen by remember { mutableStateOf("landing") }
    var studentName by remember { mutableStateOf("Guest") }
    var cartItems by remember { mutableStateOf(listOf<MenuItem>()) }
    val globalOrders = remember { mutableStateListOf<Order>() }
    var lastGeneratedToken by remember { mutableStateOf("") }

    AnimatedContent(
        targetState = currentScreen,
        transitionSpec = { fadeIn(tween(400)) togetherWith fadeOut(tween(400)) }, 
        label = "App Transition"
    ) { screen ->
        when (screen) {
            "landing" -> LandingScreen(
                onStudentClick = { currentScreen = "student_login" }, onStaffClick = { currentScreen = "staff_login" }
            )
            "student_login" -> StudentLoginScreen(
                onLoginSuccess = { name -> studentName = name; currentScreen = "student_home" }, onBack = { currentScreen = "landing" }
            )
            "staff_login" -> StaffLoginScreen(
                onLoginSuccess = { currentScreen = "admin_dashboard" }, onBack = { currentScreen = "landing" }
            )
            "student_home" -> CustomerHomeScreen(
                studentName = studentName, cartCount = cartItems.size, globalOrders = globalOrders,
                onNavigateToCart = { currentScreen = "cart" }, onAddToCart = { item -> cartItems = cartItems + item },
                onLogout = { currentScreen = "landing"; cartItems = emptyList() }
            )
            "cart" -> CartScreen(
                cartItems = cartItems, onCheckoutOnline = { currentScreen = "qr_payment" },
                onCheckoutCounter = { 
                    val token = "#" + Random.nextInt(100, 999).toString()
                    globalOrders.add(Order(token, studentName, cartItems, cartItems.sumOf { it.price }, "Pay at Counter", false))
                    lastGeneratedToken = token; cartItems = emptyList(); currentScreen = "order_success"
                }, onGoBack = { currentScreen = "student_home" }
            )
            "qr_payment" -> PaymentQRScreen(
                amount = cartItems.sumOf { it.price },
                onPaymentVerified = {
                    val token = "#" + Random.nextInt(100, 999).toString()
                    globalOrders.add(Order(token, studentName, cartItems, cartItems.sumOf { it.price }, "Online (UPI)", true))
                    lastGeneratedToken = token; cartItems = emptyList(); currentScreen = "order_success"
                }, onCancel = { currentScreen = "cart" }
            )
            "order_success" -> OrderSuccessScreen(
                tokenNumber = lastGeneratedToken, onGoHome = { currentScreen = "student_home" }
            )
            "admin_dashboard" -> AdminDashboardScreen(
                globalOrders = globalOrders, onLogout = { currentScreen = "landing" }
            )
        }
    }
}

