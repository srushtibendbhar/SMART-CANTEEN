    val infiniteTransition = rememberInfiniteTransition(label = "float")
    val floatAnim by infiniteTransition.animateFloat(initialValue = -30f, targetValue = 30f, animationSpec = infiniteRepeatable(animation = tween(2000, easing = EaseInOutSine), repeatMode = RepeatMode.Reverse), label = "FloatingQR")

    Column(modifier = Modifier.fillMaxSize().padding(24.dp), horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.Center) {
        Text("Scan Hologram to Pay", fontSize = 28.sp, fontWeight = FontWeight.Bold)
        Text("₹$amount via UPI", fontSize = 24.sp, color = PrimaryColor, fontWeight = FontWeight.ExtraBold)
        Spacer(modifier = Modifier.height(50.dp))
        
        Box(modifier = Modifier.offset(y = floatAnim.dp).size(250.dp).clip(RoundedCornerShape(16.dp)).background(Color.White).padding(16.dp), contentAlignment = Alignment.Center) {
            Column(modifier = Modifier.fillMaxSize(), verticalArrangement = Arrangement.SpaceBetween) {
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                    Box(modifier = Modifier.size(60.dp).background(Color.Black))
                    Box(modifier = Modifier.size(60.dp).background(Color.Black))
                }
                Box(modifier = Modifier.fillMaxWidth().height(20.dp).background(Color.Black))
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                    Box(modifier = Modifier.size(60.dp).background(Color.Black))
                    Box(modifier = Modifier.size(90.dp).background(Color.Black))
                }
            }
        }
        
        Spacer(modifier = Modifier.height(60.dp))
        Text("Waiting for cashier confirmation...", color = TextGray)
        Spacer(modifier = Modifier.height(16.dp))
        
        Box(modifier = Modifier.fillMaxWidth().height(60.dp).bounceClick {
            haptic.performHapticFeedback(HapticFeedbackType.LongPress)
            onPaymentVerified()
        }.background(Color(0xFF10B981), RoundedCornerShape(16.dp)), contentAlignment = Alignment.Center) { 
            Text("Simulate Payment Success ✅", fontSize = 18.sp, fontWeight = FontWeight.Bold) 
        }
        Spacer(modifier = Modifier.height(16.dp))
        TextButton(onClick = onCancel) { Text("Cancel Order", color = Color.Red) }
    }
}

@Composable
fun OrderSuccessScreen(tokenNumber: String, onGoHome: () -> Unit) {
    val haptic = LocalHapticFeedback.current
    LaunchedEffect(Unit) {
        haptic.performHapticFeedback(HapticFeedbackType.LongPress)
        delay(100)
        haptic.performHapticFeedback(HapticFeedbackType.LongPress)
    }
    
    Box(modifier = Modifier.fillMaxSize()) {
        Column(modifier = Modifier.fillMaxSize().background(DarkBackground).padding(24.dp), horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.Center) {
            Text("✅", fontSize = 100.sp)
            Spacer(modifier = Modifier.height(24.dp))
            Text("Payment Verified!", fontSize = 32.sp, fontWeight = FontWeight.ExtraBold, color = Color.White)
            Text("Please wait for your token number to be called.", fontSize = 16.sp, color = TextGray, textAlign = TextAlign.Center)
            
            Spacer(modifier = Modifier.height(40.dp))
            
            Card(shape = RoundedCornerShape(20.dp), colors = CardDefaults.cardColors(containerColor = PrimaryColor), modifier = Modifier.fillMaxWidth().padding(horizontal = 24.dp)) {
                Column(modifier = Modifier.padding(32.dp).fillMaxWidth(), horizontalAlignment = Alignment.CenterHorizontally) {
                    Text("YOUR TOKEN NO.", fontSize = 14.sp, color = Color.White, fontWeight = FontWeight.Bold)
                    Text(tokenNumber, fontSize = 60.sp, fontWeight = FontWeight.ExtraBold, color = Color.White)
                }
            }
            Spacer(modifier = Modifier.height(60.dp))
            Box(modifier = Modifier.fillMaxWidth().height(60.dp).bounceClick(onGoHome).background(Color.White, RoundedCornerShape(16.dp)), contentAlignment = Alignment.Center) { Text("Back to Menu", fontSize = 18.sp, color = DarkBackground, fontWeight = FontWeight.Bold) }
        }
        AppConfetti() // Physics Burst
    }
}

// ==========================================
// 8. ADMIN DASHBOARD
// ==========================================
@Composable
fun AdminDashboardScreen(globalOrders: MutableList<Order>, onLogout: () -> Unit) {
    val haptic = LocalHapticFeedback.current
    Column(modifier = Modifier.fillMaxSize().padding(24.dp)) {
        Row(modifier = Modifier.fillMaxWidth().padding(top = 16.dp), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
            Column {
                Text("Staff Tracking System", fontSize = 24.sp, fontWeight = FontWeight.Bold, color = Color.White)
                Text("Manage Live Orders", fontSize = 16.sp, color = PrimaryColor)
            }
            Box(modifier = Modifier.size(44.dp).clip(CircleShape).background(Color(0x33FF0000)).bounceClick(onLogout), contentAlignment = Alignment.Center) { Icon(Icons.Default.ExitToApp, contentDescription = "Logout", tint = Color.Red) }
        }
        
        Spacer(modifier = Modifier.height(24.dp))
        
        if (globalOrders.isEmpty()) {
            Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) { Text("No active orders.", color = TextGray) }
        } else {
            LazyColumn {
                items(globalOrders) { order ->
                    Card(shape = RoundedCornerShape(20.dp), colors = CardDefaults.cardColors(containerColor = CardBackground), modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp)) {
                        Column(modifier = Modifier.padding(20.dp).fillMaxWidth()) {
                            Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                                Text(order.token, fontSize = 24.sp, fontWeight = FontWeight.ExtraBold, color = PrimaryColor)
                                Text(if (order.status == "Ready") "READY ✅" else "Preparing ⏳", color = if (order.status == "Ready") Color(0xFF10B981) else Color.Yellow, fontWeight = FontWeight.Bold)
                            }
                            Spacer(modifier = Modifier.height(8.dp))
                            
                            Text("Customer: ${order.studentName}", fontWeight = FontWeight.SemiBold, fontSize = 20.sp, color = Color.White)
                            Text("Items: " + order.items.joinToString { it.name }, fontSize = 14.sp, color = TextGray)
                            
                            Spacer(modifier = Modifier.height(12.dp))
                            
                            val paymentStatus = if (order.isPaid) "Paid via ${order.paymentMethod}" else "Unpaid (${order.paymentMethod})"
                            val paymentColor = if (order.isPaid) Color(0xFF10B981) else Color.Red
                            Text("₹${order.totalAmount} • $paymentStatus", fontSize = 14.sp, color = paymentColor, fontWeight = FontWeight.Medium)
                            
                            Spacer(modifier = Modifier.height(16.dp))
                            
                            if (order.status == "Preparing") {
                                Box(modifier = Modifier.fillMaxWidth().height(48.dp).bounceClick {
                                    haptic.performHapticFeedback(HapticFeedbackType.LongPress)
                                    val index = globalOrders.indexOf(order)
                                    if (index != -1) globalOrders[index] = order.copy(status = "Ready")
                                }.background(PrimaryColor, RoundedCornerShape(12.dp)), contentAlignment = Alignment.Center) {
                                    Text("Mark as Ready & Notify Student", fontWeight = FontWeight.Bold)
                                }
                            } else {
                                Box(modifier = Modifier.fillMaxWidth().height(48.dp).bounceClick { globalOrders.remove(order) }
                                    .background(Color(0x33FFFFFF), RoundedCornerShape(12.dp)), contentAlignment = Alignment.Center) {
                                    Text("Finish & Clear Order", color = Color.White)
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
