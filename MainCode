@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun StaffLoginScreen(onLoginSuccess: () -> Unit, onBack: () -> Unit) {
    val haptic = LocalHapticFeedback.current
    var scanning by remember { mutableStateOf(false) }
    
    // Bio Scanner Laser Animation
    val infiniteTransition = rememberInfiniteTransition(label = "Laser")
    val laserY by infiniteTransition.animateFloat(
        initialValue = -30f, targetValue = 30f,
        animationSpec = infiniteRepeatable(tween(800, easing = LinearEasing), RepeatMode.Reverse), label = "Laser"
    )

    LaunchedEffect(scanning) {
        if(scanning) {
            haptic.performHapticFeedback(HapticFeedbackType.LongPress)
            delay(800)
            haptic.performHapticFeedback(HapticFeedbackType.LongPress)
            delay(800)
            haptic.performHapticFeedback(HapticFeedbackType.TextHandleMove) // Success Buzz!
            onLoginSuccess()
            scanning = false
        }
    }

    Column(modifier = Modifier.fillMaxSize().padding(24.dp), horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.Center) {
        Icon(Icons.Default.ArrowBack, contentDescription = "Back", modifier = Modifier.align(Alignment.Start).clickable { onBack() }.size(32.dp))
        Spacer(modifier = Modifier.height(24.dp))
        Text("Secured Staff Login", fontSize = 32.sp, fontWeight = FontWeight.Bold, color = Color.Red)
        Spacer(modifier = Modifier.height(16.dp))
        Text("Long-Press scanner to simulate Biometrics", color = TextGray)
        Spacer(modifier = Modifier.height(40.dp))
        
        // MOCK BIOMETRIC SCANNER (Vibrates and Launches)
        Box(
            modifier = Modifier.size(120.dp).clip(CircleShape).background(if(scanning) Color(0xFF064E3B) else CardBackground)
                .pointerInput(Unit) { detectTapGestures(onLongPress = { scanning = true }) },
            contentAlignment = Alignment.Center
        ) {
            Icon(Icons.Default.Lock, contentDescription = "Fingerprint", tint = if(scanning) Color(0xFF10B981) else PrimaryColor, modifier = Modifier.size(50.dp))
            if (scanning) {
                Box(modifier = Modifier.fillMaxWidth().height(4.dp).offset(y = laserY.dp).background(Color.White))
            }
        }

        Spacer(modifier = Modifier.height(40.dp))
        Text("OR USE PASSWORD", color = TextGray, fontSize = 12.sp, fontWeight = FontWeight.Bold)
        Spacer(modifier = Modifier.height(16.dp))
        
        OutlinedTextField(value = "admin", onValueChange = {}, label = { Text("Staff ID") }, modifier = Modifier.fillMaxWidth().background(CardBackground, RoundedCornerShape(16.dp)))
        Spacer(modifier = Modifier.height(16.dp))
        OutlinedTextField(value = "****", onValueChange = {}, label = { Text("Password") }, modifier = Modifier.fillMaxWidth().background(CardBackground, RoundedCornerShape(16.dp)))
        Spacer(modifier = Modifier.height(32.dp))
        
        Box(modifier = Modifier.fillMaxWidth().height(56.dp).bounceClick { onLoginSuccess() }.background(Color.Red, RoundedCornerShape(16.dp)), contentAlignment = Alignment.Center) { 
            Text("Access Dashboard Securely", fontSize = 18.sp, fontWeight = FontWeight.Bold) 
        }
    }
}

